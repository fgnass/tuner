{
  "name": "tuner",
  "private": true,
  "version": "0.1.0",
  "description": "A free, full-screen instrument tuner that runs entirely in your browser.",
  "license": "MIT",
  "author": "Felix Gnass",
  "homepage": "https://tuner.gnass.buzz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fgnass/tuner.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
