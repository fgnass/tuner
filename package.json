    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@preact/signals": "^2.9.2",
    "classname-variants": "^1.7.1",
    "preact": "^10.24.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@preact/preset-vite": "^2.9.1",
    "@types/node": "^22.20.0",
    "@vite-pwa/assets-generator": "^0.2.6",
    "typescript": "^5.6.3",
    "vite": "^6.0.1",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^4.1.9"
  }
}
